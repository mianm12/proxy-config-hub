{
  "name": "proxy-config-hub",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Mihomo configuration compiler with override and Sub-Store rename bundles.",
  "scripts": {
    "format": "prettier --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.yaml\" \"public/**/*.yaml\" \"tooling/**/*.json\" \".github/workflows/*.yaml\" \"package*.json\" \"eslint.config.js\" \"vitest.config.ts\" \"tsconfig*.json\" \".prettierrc.json\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.yaml\" \"public/**/*.yaml\" \"tooling/**/*.json\" \".github/workflows/*.yaml\" \"package*.json\" \"eslint.config.js\" \"vitest.config.ts\" \"tsconfig*.json\" \".prettierrc.json\"",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "node src/tools/build.ts",
    "build:site": "node src/tools/build-publication.ts",
    "build:publication": "node src/tools/build-publication.ts",
    "verify:publication": "node src/tools/verify-publication.ts",
    "example:config": "node src/tools/generate-example.ts",
    "tools:setup": "node src/tools/setup-tools.ts",
    "verify:mihomo": "npm run example:config && node src/tools/verify-mihomo.ts",
    "config:check": "node src/tools/compile-config.ts",
    "audit:rules": "node src/tools/audit-rules.ts",
    "check": "node src/tools/check.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
