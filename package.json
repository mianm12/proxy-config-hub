{
  "name": "proxy-config-hub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Unified proxy config repository for Mihomo and experimental Sub-Store compatibility.",
  "scripts": {
    "dev": "node scripts/override/main.js",
    "audit:rule-overlap": "node tools/check-rule-overlap.js",
    "rules:build": "node tools/yaml-to-js.js",
    "build": "npm run rules:build && node build.js",
    "example:config": "npm run build && node tools/generate-example-config.js",
    "baseline:v1:update": "npm run build && node tools/v2/v1-baseline.js --update",
    "baseline:v1:check": "npm run build && node tools/v2/v1-baseline.js",
    "format": "prettier --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.yaml\" \"eslint.config.js\" \"vitest.config.ts\" \"tsconfig*.json\" \".prettierrc.json\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.yaml\" \"eslint.config.js\" \"vitest.config.ts\" \"tsconfig*.json\" \".prettierrc.json\"",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test:v2": "vitest run",
    "build:v2": "tsc --project tsconfig.build.json",
    "compare:v1-v2": "node src/tools/compare-v1-v2.ts",
    "check:v2": "node src/tools/check.ts",
    "verify:main": "node tools/verify-main.js",
    "verify": "npm run build && npm run verify:main"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
